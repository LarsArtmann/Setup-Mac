{
  "title": "evo-x2 Overview",
  "description": "System overview dashboard — CPU, memory, disk, network, services",
  "tags": ["evo-x2", "overview"],
  "layout": [
    {
      "title": "CPU Usage",
      "description": "Current CPU utilization percentage",
      "panelTypes": "GAUGE",
      "query": {
        "promql": {
          "expression": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "step": 300
        }
      },
      "thresholds": {"steps": [{"color": "green"}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]},
      "unit": "percent",
      "min": 0, "max": 100
    },
    {
      "title": "Memory Usage",
      "description": "Current memory utilization percentage",
      "panelTypes": "GAUGE",
      "query": {
        "promql": {
          "expression": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "step": 300
        }
      },
      "thresholds": {"steps": [{"color": "green"}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]},
      "unit": "percent",
      "min": 0, "max": 100
    },
    {
      "title": "Disk Usage",
      "description": "Root filesystem utilization percentage",
      "panelTypes": "GAUGE",
      "query": {
        "promql": {
          "expression": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
          "step": 300
        }
      },
      "thresholds": {"steps": [{"color": "green"}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]},
      "unit": "percent",
      "min": 0, "max": 100
    },
    {
      "title": "CPU Temperature",
      "description": "AMD GPU junction temperature",
      "panelTypes": "GAUGE",
      "query": {
        "promql": {
          "expression": "node_hwmon_temp_celsius{chip=\"amdgpu\"}",
          "step": 300
        }
      },
      "thresholds": {"steps": [{"color": "green"}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]},
      "unit": "celsius",
      "min": 0, "max": 100
    },
    {
      "title": "Load Average (1m)",
      "description": "System 1-minute load average",
      "panelTypes": "VALUE",
      "query": {
        "promql": {
          "expression": "node_load1",
          "step": 300
        }
      }
    },
    {
      "title": "Uptime",
      "description": "System uptime in seconds",
      "panelTypes": "VALUE",
      "query": {
        "promql": {
          "expression": "time() - node_boot_time_seconds",
          "step": 300
        }
      },
      "unit": "s"
    },
    {
      "title": "CPU by Core",
      "description": "Per-core CPU utilization over time",
      "panelTypes": "TIME_SERIES",
      "query": {
        "promql": {
          "expression": "100 - (rate(node_cpu_seconds_total{mode=\"idle\"}[5m]) * 100)",
          "legend": "{{cpu}}",
          "step": 300
        }
      },
      "unit": "percent"
    },
    {
      "title": "Memory Usage Over Time",
      "description": "Memory used vs available over time",
      "panelTypes": "TIME_SERIES",
      "query": {
        "promql": {
          "expression": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "step": 300
        }
      },
      "unit": "bytes"
    },
    {
      "title": "Network I/O",
      "description": "Network receive/transmit bits per second",
      "panelTypes": "TIME_SERIES",
      "query": {
        "promql": {
          "expression": "rate(node_network_receive_bytes_total{device!=\"lo\"}[5m]) * 8",
          "legend": "↓ {{device}}",
          "step": 300
        }
      },
      "unit": "bps"
    },
    {
      "title": "Disk I/O",
      "description": "Disk read/write bytes per second",
      "panelTypes": "TIME_SERIES",
      "query": {
        "promql": {
          "expression": "rate(node_disk_read_bytes_total[5m])",
          "legend": "Read {{device}}",
          "step": 300
        }
      },
      "unit": "Bps"
    },
    {
      "title": "Caddy Requests",
      "description": "HTTP requests per second by host",
      "panelTypes": "TIME_SERIES",
      "query": {
        "promql": {
          "expression": "rate(caddy_http_requests_total[5m])",
          "legend": "{{host}}",
          "step": 300
        }
      }
    },
    {
      "title": "Container CPU",
      "description": "CPU usage per Docker container",
      "panelTypes": "TIME_SERIES",
      "query": {
        "promql": {
          "expression": "rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]) * 100",
          "legend": "{{name}}",
          "step": 300
        }
      },
      "unit": "percent"
    },
    {
      "title": "Container Memory",
      "description": "Memory usage per Docker container",
      "panelTypes": "TIME_SERIES",
      "query": {
        "promql": {
          "expression": "container_memory_usage_bytes{name!=\"\"}",
          "legend": "{{name}}",
          "step": 300
        }
      },
      "unit": "bytes"
    }
  ],
  "variables": [],
  "refresh": "30s",
  "timeRange": {"from": "now-6h", "to": "now"}
}
