#!/usr/bin/env bash
# Service health checker for evo-x2
# Checks critical services and sends desktop notification on failure
set -euo pipefail

FAILED=""
OK=""

check_url() {
    local name="$1" url="$2"
    if python3 -c "import urllib.request; urllib.request.urlopen('$url', timeout=5)" 2>/dev/null; then
        OK="$OK\n  OK: $name"
    else
        FAILED="$FAILED\n  FAIL: $name ($url unreachable)"
    fi
}

check_service() {
    local name="$1"
    if systemctl is-active --quiet "$name" 2>/dev/null; then
        OK="$OK\n  OK: $name (service)"
    else
        FAILED="$FAILED\n  FAIL: $name (service down)"
    fi
}

check_dns() {
    if python3 -c "import socket; socket.getaddrinfo('immich.lan', 443)" 2>/dev/null; then
        OK="$OK\n  OK: DNS (immich.lan resolves)"
    else
        FAILED="$FAILED\n  FAIL: DNS (immich.lan unresolvable)"
    fi
}

# Checks
check_service "unbound"
check_service "dnsblockd"
check_service "caddy"
check_service "immich-server"
check_service "immich-machine-learning"
check_service "postgresql"
check_service "redis-immich"
check_url "Immich Web" "http://localhost:2283"
check_url "Caddy Proxy" "http://immich.lan"
check_url "dnsblockd Stats" "http://127.0.0.2:9090/stats"
check_dns

# Notify
if [ -n "$FAILED" ]; then
    notify-send -u critical "Health Check FAILED" "$(echo -e "$FAILED")"
    echo "HEALTH CHECK FAILED:$(echo -e "$FAILED")"
else
    echo "HEALTH CHECK OK:$(echo -e "$OK")"
fi
