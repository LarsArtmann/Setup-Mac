#!/usr/bin/env bash
# Service health checker for evo-x2
# Checks critical services and sends desktop notification on failure
set -euo pipefail

export DISPLAY=:0
export WAYLAND_DISPLAY=wayland-1
export XDG_RUNTIME_DIR=/run/user/$(id -u)

FAILED=""

check_service() {
    if systemctl is-active --quiet "$1" 2>/dev/null; then
        return 0
    else
        FAILED="$FAILED\n  $1"
        return 1
    fi
}

check_url() {
    if python3 -c "import urllib.request; urllib.request.urlopen('$1', timeout=5)" 2>/dev/null; then
        return 0
    else
        FAILED="$FAILED\n  $2"
        return 1
    fi
}

# Service checks
check_service caddy
check_service immich-server
check_service immich-machine-learning
check_service postgresql
check_service unbound
check_service dnsblockd
check_service gitea
check_service ollama
check_service homepage-dashboard
check_service signoz-query-service
check_service signoz-otel-collector
check_service clickhouse
check_service node_exporter
check_service cadvisor
check_service authelia
check_service taskchampion-sync-server

# URL checks
check_url "http://localhost:2283" "immich-web"
check_url "http://immich.lan" "caddy-proxy"
check_url "http://127.0.0.1:9090/stats" "dnsblockd-stats"
check_url "http://localhost:8082" "homepage-web"
check_url "http://localhost:3000" "gitea-web"
check_url "http://localhost:11434/api/tags" "ollama-api"
check_url "http://localhost:8080" "signoz-web"
check_url "http://localhost:4318/health" "otel-collector"
check_url "http://localhost:9091/-/healthy" "authelia-health"
check_url "http://localhost:9100/metrics" "node-exporter"
check_url "http://localhost:9110/metrics" "cadvisor"

if [ -n "$FAILED" ]; then
    notify-send -u critical "Health Check FAILED" "$(echo -e "$FAILED")"
    echo "FAILED:$(echo -e "$FAILED")"
    exit 1
else
    echo "OK: all services healthy"
    exit 0
fi
